# Copy this file to .env and fill in secrets for local development or CI.
OPENROUTER_API_KEY=
# Repository slug for the GitHub repo (owner/repo) used by the dashboard trigger link
NEXT_PUBLIC_GITHUB_REPO=owner/repo

# Google Generative API key for Gemini 3 Flash (Google AI Studio)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-3-flash-preview

# Groq fallback (OpenAI-compatible endpoint)
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# Optional: For local testing only. Do NOT commit real tokens here.
# GITHUB_PAT=
